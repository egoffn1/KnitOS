<?xml version="1.0" encoding="utf-8"?>
<!-- KnitOS OTA Update Manager - Main Layout -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="24dp"
    android:gravity="center_horizontal">

    <!-- Header -->
    <ImageView
        android:layout_width="120dp"
        android:layout_height="120dp"
        android:src="@drawable/ic_knit_logo"
        android:contentDescription="KnitOS Logo"
        android:layout_marginBottom="24dp" />

    <!-- Current Version -->
    <TextView
        android:id="@+id/version_text"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Current Version: 1.0.0"
        android:textSize="18sp"
        android:textStyle="bold"
        android:layout_marginBottom="16dp" />

    <!-- Status -->
    <TextView
        android:id="@+id/status_text"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Checking for updates..."
        android:textSize="16sp"
        android:layout_marginBottom="24dp" />

    <!-- Progress Bar -->
    <ProgressBar
        android:id="@+id/progress_bar"
        style="?android:attr/progressBarStyleHorizontal"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:max="100"
        android:visibility="gone"
        android:layout_marginBottom="24dp" />

    <!-- Update Button -->
    <Button
        android:id="@+id/update_button"
        android:layout_width="200dp"
        android:layout_height="wrap_content"
        android:text="Check for Updates"
        android:textSize="16sp"
        android:background="@drawable/button_knit_primary"
        android:textColor="@android:color/white"
        android:padding="12dp" />

    <!-- Changelog Section -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:layout_marginTop="32dp">

        <TextView
            android:id="@+id/changelog_text"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Changelog will appear here"
            android:textSize="14sp"
            android:lineSpacingExtra="4dp" />
    </ScrollView>

</LinearLayout>
