<?xml version="1.0" encoding="utf-8"?>
<!-- KnitOS Live Wallpapers - Android Manifest -->
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    package="com.knitos.livewallpapers"
    android:versionCode="1"
    android:versionName="1.0.0">

    <uses-feature android:name="android.software.live_wallpaper" />
    
    <application
        android:label="@string/app_name"
        android:icon="@drawable/ic_knit_logo">
        
        <!-- Knitting Pattern Live Wallpaper -->
        <service
            android:name=".KnittingPatternWallpaper"
            android:label="@string/wallpaper_knitting_pattern"
            android:permission="android.permission.BIND_WALLPAPER"
            android:exported="true">
            <intent-filter>
                <action android:name="android.service.wallpaper.WallpaperService" />
            </intent-filter>
            <meta-data
                android:name="android.service.wallpaper"
                android:resource="@xml/knitting_pattern_wallpaper" />
        </service>
        
        <!-- Thread Weave Live Wallpaper -->
        <service
            android:name=".ThreadWeaveWallpaper"
            android:label="@string/wallpaper_thread_weave"
            android:permission="android.permission.BIND_WALLPAPER"
            android:exported="true">
            <intent-filter>
                <action android:name="android.service.wallpaper.WallpaperService" />
            </intent-filter>
            <meta-data
                android:name="android.service.wallpaper"
                android:resource="@xml/thread_weave_wallpaper" />
        </service>
        
        <!-- Dynamic Yarn Live Wallpaper -->
        <service
            android:name=".DynamicYarnWallpaper"
            android:label="@string/wallpaper_dynamic_yarn"
            android:permission="android.permission.BIND_WALLPAPER"
            android:exported="true">
            <intent-filter>
                <action android:name="android.service.wallpaper.WallpaperService" />
            </intent-filter>
            <meta-data
                android:name="android.service.wallpaper"
                android:resource="@xml/dynamic_yarn_wallpaper" />
        </service>
        
    </application>
</manifest>
